rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global default safety net - deny by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Google logged-in users and visitors collection
    match /google_users/{userId} {
      allow read, write: if true;
    }

    // Administrative configuration and settings
    match /admin_settings/{docId} {
      allow read, write: if true;
    }

    // Learn analytics & events tracking
    match /learn_analytics/{docId} {
      allow read, write: if true;
    }

    // Referrals and invite system
    match /referrals/{docId} {
      allow read, write: if true;
    }

    // Shared summary clips and bookmarks
    match /summaries/{docId} {
      allow read, write: if true;
    }

    // VIP/premium user subscriptions
    match /subscriptions/{docId} {
      allow read, write: if true;
    }

    // Comments left on shared workspaces
    match /comments/{docId} {
      allow read, write: if true;
    }

    // Reaction counts on shared workspaces
    match /reactions_summary/{docId} {
      allow read, write: if true;
    }

    // Documents indexing metadata
    match /documents/{docId} {
      allow read, write: if true;
    }

    // Indexed document content chunks for RAG
    match /document_chunks/{docId} {
      allow read, write: if true;
    }

    // Client errors and user reported issues
    match /client_errors/{docId} {
      allow read, write: if true;
    }
  }
}
