# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# stripe configuration secrets (provide these in AI Studio settings to enable live billing)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Google Analytics 4 configuration (Optional - tracks clicks, summaries, checkouts globally)
VITE_GA_MEASUREMENT_ID=

# MVP Rate Limiting & Access Security for protecting default API Quotas
FREE_REQS_LIMIT=3
# SECURITY: Set a strong, unique value in AI Studio Secrets / your deployment env. Never commit real values here.
VIP_BYPASS_CODE=CHANGE_ME_VIP_CODE

# Secure Admin Dashboard Authentication Credentials
# SECURITY: Set a strong, unique password in AI Studio Secrets / your deployment env. Never commit real credentials here.
ADMIN_USER_ID=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Route-level Rate Limiting (requests per window per IP)
RATE_LIMIT_SUMMARIZE_MAX=10
RATE_LIMIT_SUMMARIZE_WINDOW_MS=900000
RATE_LIMIT_TTS_MAX=20
RATE_LIMIT_TTS_WINDOW_MS=900000
